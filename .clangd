Diagnostics:
  UnusedIncludes: None

InlayHints:
  Enabled: No

CompileFlags:
  Add:
    - "--target=riscv32-unknown-elf"
    - "-Wall"
    - "-g3"
    - "-I/opt/homebrew/Cellar/arm-none-eabi-gcc/15.2.0/lib/gcc/arm-none-eabi/15.2.0/include"
    - "-I/opt/homebrew/Cellar/arm-none-eabi-gcc/15.2.0/lib/gcc/arm-none-eabi/15.2.0/include-fixed"
    # Указываем, что это bare-metal окружение
    - "-nostdinc"
    - "-isystem/mik32_utils/xpack-riscv-none-elf-gcc-14.2.0-3/riscv-none-elf/include"
  CompilationDatabase: build

---
If:
  PathMatch: .*\.c$
CompileFlags:
  Add:
    - "-std=gnu11"

---
If:
  PathMatch: .*\.(cpp|cc|cxx)$
CompileFlags:
  Add:
    - "-std=c++20"

---
If:
  PathMatch: .*\.h$
CompileFlags:
  Add:
    - "-xc"
    - "-std=gnu11"
